# ── Web server ───────────────────────────────────────────────────────────────
PORT=4000
CORS_ORIGIN=http://localhost:5173

# ── Mongo (optional) ────────────────────────────────────────────────────────
MONGO_URI=
PERSIST_JOBS=false

# ── Solana ──────────────────────────────────────────────────────────────────
SOLANA_CLUSTER=mainnet-beta
SOLANA_RPC_URL=
# Optional dedicated RPC for Pump.fun deploys; falls back to SOLANA_RPC_URL.
QUICKNODE_RPC_URL=
# 0.1 SOL = 100_000_000 lamports (legacy /api/jobs claim flow)
CLAIM_FEE_LAMPORTS=100000000
# Where collected fees are forwarded after a successful claim (legacy flow).
OPERATOR_WALLET=

# ── Fees & treasury ─────────────────────────────────────────────────────────
# Wallet unlocks cost FEE_USD worth of FEE_TOKEN_MINT, quoted at request time
# (Jupiter price API with DexScreener fallback).
FEE_TOKEN_MINT=9cRCn9rGT8V2imeM2BaKs13yhMEais3ruM3rPvTGpump
FEE_USD=5
# All deposits sweep here the moment payment confirms.
TREASURY_WALLET=E96hif2XYbvK4YbHc7wLZBaJoszM7viCUbdSMjappGxR
# REQUIRED for sweeps: base58 secret key of the treasury. Deposit wallets
# hold no SOL, so the treasury co-signs each sweep as the fee payer.
TREASURY_SECRET_KEY=
# Custom-CA launch fee, charged inside the mint transaction (0.1 SOL).
MINT_FEE_LAMPORTS=100000000

# ── Grinder engine (WincerChan/SolVanityCL via Python + OpenCL) ─────────────
# Run cuda/install-solvanitycl.sh on the GPU box to populate these.
GRINDER_PYTHON=/opt/vamint/engine/.venv/bin/python
GRINDER_ENGINE_DIR=/opt/vamint/engine
GRINDER_ENTRY=/opt/vamint/engine/main.py

# Optional extra flags appended to every invocation (e.g. --select-device 0,
# --chunk-size, --is-case-sensitive). Prefix/suffix/count/output-dir are
# always supplied by the wrapper.
GRINDER_EXTRA_ARGS=

# Where the wrapper creates per-job output dirs (each holds the result JSON
# until we've parsed and wiped it).
GRINDER_WORK_DIR=/tmp/vamint

# Concurrent jobs per node. Each SolVanityCL invocation saturates one GPU,
# so leave at 1 unless you have multiple GPUs and pin them via EXTRA_ARGS.
GRINDER_CONCURRENCY=1

# CPU fallback for dev machines without an OpenCL device.
GRINDER_CPU_FALLBACK=false
GRINDER_CPU_THREADS=

# ── Job lifecycle (seconds) ─────────────────────────────────────────────────
JOB_TTL_SECONDS=1800
PAYMENT_TIMEOUT_SECONDS=900
